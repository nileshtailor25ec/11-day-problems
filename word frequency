#include <iostream>
#include <sstream>
#include <string>
#include <map>
using namespace std;
int main() {
    string line, word;
    cout << "Enter sentence: "; getline(cin, line);
    stringstream ss(line);
    map<string, int> freq;
    while(ss >> word) freq[word]++;
    for(auto i : freq) cout << i.first << ": " << i.second << endl;
    return 0;
}

Result-Enter sentence: apple banana apple mango
apple: 2
banana: 1
mango: 1
