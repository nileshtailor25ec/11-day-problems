#include <iostream>
#include <vector>
#include <map>
using namespace std;
int main() {
    int n, val, maxFreq = 0, res;
    cout << "Enter size: "; cin >> n;
    map<int, int> freq;
    for(int i = 0; i < n; i++) {
        cin >> val;
        freq[val]++;
        if(freq[val] > maxFreq) { maxFreq = freq[val]; res = val; }
    }
    cout << "Most frequent: " << res << " (" << maxFreq << " times)" << endl;
    return 0;
}

