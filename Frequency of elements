#include <iostream>
#include <map>
using namespace std;
int main() {
    int n;
    cout << "Enter array size: ";
    cin >> n;
    int arr[n];
    map<int, int> freq;
    cout << "Enter elements: ";
    for(int i = 0; i < n; i++) {
        cin >> arr[i];
        freq[arr[i]]++;
    }
    for(auto i : freq) cout << i.first << " appears " << i.second << " times" << endl;
    return 0;
}

