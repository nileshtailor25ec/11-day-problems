#include <iostream>
#include <vector>
#include <map>
using namespace std;
int main() {
    int n, val, q, target;
    cout << "Enter array size: "; cin >> n;
    map<int, int> freq;
    for(int i = 0; i < n; i++) { cin >> val; freq[val]++; }
    cout << "Enter number of queries: "; cin >> q;
    while(q--) {
        cout << "Enter number to search: "; cin >> target;
        cout << "Frequency: " << freq[target] << endl;
    }
    return 0;
}

