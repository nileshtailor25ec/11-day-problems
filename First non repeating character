#include <iostream>
#include <string>
#include <map>
using namespace std;
int main() {
    string s;
    cout << "Enter string: "; cin >> s;
    map<char, int> freq;
    for(char c : s) freq[c]++;
    for(char c : s) {
        if(freq[c] == 1) { cout << "First non-repeating: " << c << endl; return 0; }
    }
    cout << "No unique character found." << endl;
    return 0;
}

